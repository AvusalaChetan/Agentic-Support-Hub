{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES6",
    "module": "commonjs",
    "lib": ["ES6"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types"],
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}